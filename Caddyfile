{$THREADLINE_SITE_ADDRESS:http://localhost} {
	encode zstd gzip

	header {
		-Server
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
	}

	request_body {
		max_size 16KB
	}

	reverse_proxy app:3000 {
		flush_interval -1
		health_uri /api/health
		health_interval 30s
		health_timeout 5s
	}
}
